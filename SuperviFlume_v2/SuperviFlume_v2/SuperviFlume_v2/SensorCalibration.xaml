<Window x:Class="SuperviFlume_v2.SensorCalibration"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SuperviFlume_v2"
        mc:Ignorable="d"
        Title="Calibration des capteurs" Height="220" Width="560"
        ResizeMode="NoResize"
        Closing="Window_Closing">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="8"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="160"/>
            <ColumnDefinition Width="150"/>
            <ColumnDefinition Width="10"/>
            <ColumnDefinition Width="150"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sélection de l'appareil -->
        <Label Content="Appareil :" Grid.Row="0" Grid.Column="0" VerticalAlignment="Center"/>
        <ComboBox x:Name="cbDeviceNumber" Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="3"
                  Margin="0,2" VerticalAlignment="Center"
                  SelectionChanged="cbDeviceNumber_SelectionChanged"/>

        <!-- Calibration O2 -->
        <Label x:Name="labelO2SensorValue" Content="O2 : ---"
               Grid.Row="2" Grid.Column="0" VerticalAlignment="Center"/>
        <Button x:Name="btnSetOffset" Content="Set Offset (= 0 %)"
                Grid.Row="2" Grid.Column="1"
                Padding="6,4" Click="btnSetOffset_Click"/>
        <Button x:Name="btnSetSlope" Content="Set Slope (= 100 %)"
                Grid.Row="2" Grid.Column="3"
                Padding="6,4" Click="btnSetSlope_Click"/>

        <!-- Calibration pH -->
        <Label x:Name="labelpHSensorValue" Content="pH : ---"
               Grid.Row="4" Grid.Column="0" VerticalAlignment="Center"/>
        <Button x:Name="btnCalibratepH" Content="Set Value to :"
                Grid.Row="4" Grid.Column="1"
                Padding="6,4" Click="btnCalibratepH_Click"/>
        <TextBox x:Name="tbpHCalibValue"
                 Grid.Row="4" Grid.Column="3"
                 VerticalAlignment="Center" Height="26" Padding="4,2"/>
    </Grid>
</Window>
