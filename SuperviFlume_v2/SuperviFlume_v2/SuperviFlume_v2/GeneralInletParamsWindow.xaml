<Window x:Class="SuperviFlume_v2.GeneralInletParamsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="General Inlet Parameters" Height="530" Width="460"
        ResizeMode="NoResize"
        Closing="Window_Closing">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="10"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="10"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ── Row 0 : Condition ─────────────────────────────────────────── -->
        <StackPanel Grid.Row="0" Orientation="Horizontal">
            <Label Content="Condition :" Width="90" VerticalAlignment="Center" FontFamily="Arial"/>
            <ComboBox x:Name="cbCondition" Width="160" FontFamily="Arial"
                      SelectionChanged="cbCondition_SelectionChanged">
                <ComboBoxItem Content="Hot Water"     Tag="1" FontFamily="Arial"/>
                <ComboBoxItem Content="Cold Water"    Tag="2" FontFamily="Arial"/>
                <ComboBoxItem Content="Ambient Water" Tag="3" FontFamily="Arial"/>
            </ComboBox>
        </StackPanel>

        <!-- ── Row 2 : Temperature regulation ───────────────────────────── -->
        <GroupBox Grid.Row="2" x:Name="grpTemp" Header="Temperature regulation" FontFamily="Arial">
            <Grid Margin="8,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="160"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="4"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="4"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="4"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="4"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="4"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Label Content="Setpoint :"            Grid.Row="0"  Grid.Column="0" FontFamily="Arial" VerticalAlignment="Center"/>
                <TextBox x:Name="tbTempCons"           Grid.Row="0"  Grid.Column="1" Height="24" Padding="4,2" FontFamily="Arial"/>

                <Label Content="Kp :"                  Grid.Row="2"  Grid.Column="0" FontFamily="Arial" VerticalAlignment="Center"/>
                <TextBox x:Name="tbTempKp"             Grid.Row="2"  Grid.Column="1" Height="24" Padding="4,2" FontFamily="Arial"/>

                <Label Content="Ki :"                  Grid.Row="4"  Grid.Column="0" FontFamily="Arial" VerticalAlignment="Center"/>
                <TextBox x:Name="tbTempKi"             Grid.Row="4"  Grid.Column="1" Height="24" Padding="4,2" FontFamily="Arial"/>

                <Label Content="Kd :"                  Grid.Row="6"  Grid.Column="0" FontFamily="Arial" VerticalAlignment="Center"/>
                <TextBox x:Name="tbTempKd"             Grid.Row="6"  Grid.Column="1" Height="24" Padding="4,2" FontFamily="Arial"/>

                <Label Content="Forcing authorization :" Grid.Row="8" Grid.Column="0" FontFamily="Arial" VerticalAlignment="Center"/>
                <CheckBox x:Name="chkTempForcage"      Grid.Row="8"  Grid.Column="1" VerticalAlignment="Center"/>

                <Label Content="Forcing setpoint :"    Grid.Row="10" Grid.Column="0" FontFamily="Arial" VerticalAlignment="Center"/>
                <TextBox x:Name="tbTempConsForcage"    Grid.Row="10" Grid.Column="1" Height="24" Padding="4,2" FontFamily="Arial"/>
            </Grid>
        </GroupBox>

        <!-- ── Row 4 : Pressure regulation ──────────────────────────────── -->
        <GroupBox Grid.Row="4" Header="Pressure regulation" FontFamily="Arial">
            <Grid Margin="8,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="160"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="4"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="4"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="4"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="4"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="4"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Label Content="Setpoint :"              Grid.Row="0"  Grid.Column="0" FontFamily="Arial" VerticalAlignment="Center"/>
                <TextBox x:Name="tbPresCons"             Grid.Row="0"  Grid.Column="1" Height="24" Padding="4,2" FontFamily="Arial"/>

                <Label Content="Kp :"                    Grid.Row="2"  Grid.Column="0" FontFamily="Arial" VerticalAlignment="Center"/>
                <TextBox x:Name="tbPresKp"               Grid.Row="2"  Grid.Column="1" Height="24" Padding="4,2" FontFamily="Arial"/>

                <Label Content="Ki :"                    Grid.Row="4"  Grid.Column="0" FontFamily="Arial" VerticalAlignment="Center"/>
                <TextBox x:Name="tbPresKi"               Grid.Row="4"  Grid.Column="1" Height="24" Padding="4,2" FontFamily="Arial"/>

                <Label Content="Kd :"                    Grid.Row="6"  Grid.Column="0" FontFamily="Arial" VerticalAlignment="Center"/>
                <TextBox x:Name="tbPresKd"               Grid.Row="6"  Grid.Column="1" Height="24" Padding="4,2" FontFamily="Arial"/>

                <Label Content="Forcing authorization :"  Grid.Row="8"  Grid.Column="0" FontFamily="Arial" VerticalAlignment="Center"/>
                <CheckBox x:Name="chkPresForcage"        Grid.Row="8"  Grid.Column="1" VerticalAlignment="Center"/>

                <Label Content="Forcing setpoint :"      Grid.Row="10" Grid.Column="0" FontFamily="Arial" VerticalAlignment="Center"/>
                <TextBox x:Name="tbPresConsForcage"      Grid.Row="10" Grid.Column="1" Height="24" Padding="4,2" FontFamily="Arial"/>
            </Grid>
        </GroupBox>

        <!-- ── Row 6 : Loading + Submit ─────────────────────────────────── -->
        <Grid Grid.Row="6">
            <Label x:Name="lblLoading" Content="Loading..." FontFamily="Arial"
                   HorizontalAlignment="Left" VerticalAlignment="Center"
                   FontStyle="Italic" Foreground="Gray"
                   Visibility="Collapsed"/>
            <Button x:Name="btnSubmit" Content="Submit" FontFamily="Arial"
                    HorizontalAlignment="Right"
                    Width="110" Height="30"
                    Click="btnSubmit_Click"/>
        </Grid>
    </Grid>
</Window>
