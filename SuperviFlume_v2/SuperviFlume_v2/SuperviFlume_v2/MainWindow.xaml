<Window x:Class="SuperviFlume_v2.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="SuperviFlumes v2" Height="800" Width="1400"
        WindowState="Maximized"
        Closing="MainWindow_Closing">

    <Window.Resources>
        <!-- Valeur de mesure : fond blanc semi-transparent, texte bleu marine, police monospace -->
        <Style x:Key="ValLabel" TargetType="Label">
            <Setter Property="Foreground"               Value="#FF002266"/>
            <Setter Property="FontSize"                 Value="10"/>
            <Setter Property="FontFamily"               Value="Arial"/>
            <Setter Property="Padding"                  Value="4,1"/>
            <Setter Property="Margin"                   Value="0,1,0,0"/>
            <Setter Property="BorderThickness"          Value="1"/>
            <Setter Property="MinWidth"                 Value="100"/>
        </Style>

        <!-- En-tête de section : fond bleu, texte blanc -->
        <Style x:Key="HdrLabel" TargetType="Label">
            <Setter Property="Background"               Value="#CC002266"/>
            <Setter Property="Foreground"               Value="White"/>
            <Setter Property="FontSize"                 Value="9"/>
            <Setter Property="FontWeight"               Value="Bold"/>
            <Setter Property="FontFamily"               Value="Arial"/>
            <Setter Property="Padding"                  Value="4,2"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
        </Style>
    </Window.Resources>

    <DockPanel>

        <!-- ================================================================
             BARRE DE MENUS
             ================================================================ -->
        <Menu DockPanel.Dock="Top" FontSize="12">
            <MenuItem Header="_Serveur">
                <MenuItem x:Name="MenuStartServer" Header="_Start Server"
                          Click="MenuStartServer_Click"/>
                <MenuItem x:Name="MenuStopServer"  Header="_Stop Server"
                          IsEnabled="False" Click="MenuStopServer_Click"/>
                <Separator/>
                <MenuItem Header="_Exit" Click="MenuQuit_Click"/>
            </MenuItem>
            <MenuItem Header="_Tools">
                <MenuItem Header="Show Coms Log" Click="MenuShowLog_Click"/>
                <MenuItem Header="Calibrate _sensors" Click="MenuCalibrateSensors_Click"/>
                <MenuItem Header="_Setpoints" Click="MenuSetpoints_Click"/>
                <MenuItem Header="Set _General Inlet Params" Click="MenuGeneralInletParams_Click"/>
                <MenuItem Header="_Alarms"                   Click="MenuAlarms_Click"/>
            </MenuItem>
            <MenuItem Header="_?">
                <MenuItem Header="_About" Click="MenuAbout_Click"/>
            </MenuItem>
        </Menu>

        <!-- ================================================================
             BARRE D'ÉTAT
             ================================================================ -->
        <StatusBar DockPanel.Dock="Bottom" Background="#FF002266" Height="24">
            <StatusBarItem>
                <TextBlock x:Name="TxtServerStatus"
                           Text="● Serveur arrêté"
                           Foreground="#FFFF4444"
                           FontWeight="Bold" FontSize="11"/>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <TextBlock x:Name="TxtLastUpdate"
                           Text=""
                           Foreground="LightGray" FontSize="11"/>
            </StatusBarItem>
        </StatusBar>

        <!-- ================================================================
             ONGLETS PRINCIPAUX
             ================================================================ -->
        <TabControl FontSize="13" FontWeight="SemiBold">

            <!-- ============================================================
                 ONGLET 1 – GENERAL WATER INLET
                 Canvas de référence : 1280 × 720 px
                 3 circuits : Ambiant (bleu), Cold (cyan), Warm (rouge)
                 ============================================================ -->
            <TabItem Header="General water inlet">
                <Viewbox Stretch="Uniform">
                    <Grid Width="1280" Height="720">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="22*"/>
                            <ColumnDefinition Width="3*"/>
                            <ColumnDefinition Width="231*"/>
                        </Grid.ColumnDefinitions>

                        <Image Source="General.png" Stretch="Fill" Grid.ColumnSpan="3"/>

                        <Canvas Width="1280" Height="720" Grid.ColumnSpan="3">

                            <!-- ── Ambiant sea water (ligne du haut) ── -->
                            <!-- Capteur pH/T côté gauche -->
                            <StackPanel Canvas.Left="656" Canvas.Top="227" HorizontalAlignment="Left" VerticalAlignment="Top">
                                <Label Content="Ambiant" Style="{StaticResource HdrLabel}" FontFamily="Arial"/>
                                <Label x:Name="lblAmbPH"   Content="pH  : --"    Style="{StaticResource ValLabel}"/>
                                <Label x:Name="lblAmbTemp" Content="T   : -- °C" Style="{StaticResource ValLabel}"/>
                            </StackPanel>
                            <StackPanel Canvas.Left="757" Canvas.Top="156" HorizontalAlignment="Left" VerticalAlignment="Top">
                                <Label x:Name="lblAmbPIDPRessure"   Content="PID  : -- %"    Style="{StaticResource ValLabel}"/>
                                <Label x:Name="lblAmbPIDSetpoint" Content="Setpoint   : -- bar" Style="{StaticResource ValLabel}"/>
                            </StackPanel>
                            <!-- P1 / F1 côté droit -->
                            <StackPanel Canvas.Left="926" Canvas.Top="183">
                                <Label x:Name="lblPres1" Content="P1 : -- bar" Style="{StaticResource ValLabel}"/>
                                <Label x:Name="lblFlow1" Content="F1 : -- L/h"  Style="{StaticResource ValLabel}"/>
                            </StackPanel>

                            <!-- ── Cold sea water (ligne cyan) ── -->
                            <!-- Refroidisseur (chiller) -->
                            <StackPanel Canvas.Left="656" Canvas.Top="319">
                                <Label Content="Cold" Style="{StaticResource HdrLabel}"/>
                                <Label x:Name="lblTCold"     Content="T    : -- °C" Style="{StaticResource ValLabel}"/>
                                <Label x:Name="lblConsTCold" Content="Cons : -- °C" Style="{StaticResource ValLabel}"/>
                                <Label x:Name="lblPIDCold"   Content="PID  : -- %"  Style="{StaticResource ValLabel}"/>
                            </StackPanel>

                            <StackPanel Canvas.Left="761" Canvas.Top="259" HorizontalAlignment="Left" VerticalAlignment="Top">
                                <Label x:Name="lblColdPIDPRessure"   Content="PID  : -- %"    Style="{StaticResource ValLabel}"/>
                                <Label x:Name="lblColdPIDSetpoint" Content="Setpoint   : -- bar" Style="{StaticResource ValLabel}"/>
                            </StackPanel>
                            <!-- P2 / F2 -->
                            <StackPanel Canvas.Left="926" Canvas.Top="276">
                                <Label x:Name="lblPres2" Content="P2 : -- mbar" Style="{StaticResource ValLabel}"/>
                                <Label x:Name="lblFlow2" Content="F2 : -- L/h"  Style="{StaticResource ValLabel}"/>
                            </StackPanel>

                            <!-- ── Warm sea water (ligne rouge) ── -->
                            <!-- Réchauffeur (heater) -->
                            <StackPanel Canvas.Left="656" Canvas.Top="424">
                                <Label Content="Warm" Style="{StaticResource HdrLabel}"/>
                                <Label x:Name="lblTWarm"     Content="T    : -- °C" Style="{StaticResource ValLabel}"/>
                                <Label x:Name="lblConsTWarm" Content="Cons : -- °C" Style="{StaticResource ValLabel}"/>
                                <Label x:Name="lblPIDWarm"   Content="PID  : -- %"  Style="{StaticResource ValLabel}"/>
                            </StackPanel>
                            <!-- P3 / F3 -->
                            <StackPanel Canvas.Left="926" Canvas.Top="368">
                                <Label x:Name="lblPres3" Content="P3 : -- mbar" Style="{StaticResource ValLabel}"/>
                                <Label x:Name="lblFlow3" Content="F3 : -- L/h"  Style="{StaticResource ValLabel}"/>
                            </StackPanel>
                            <StackPanel Canvas.Left="761" Canvas.Top="348" HorizontalAlignment="Center" VerticalAlignment="Top">
                                <Label x:Name="lblHotPIDPRessure"   Content="PID  : -- %"    Style="{StaticResource ValLabel}"/>
                                <Label x:Name="lblHotPIDSetpoint" Content="Setpoint   : -- bar" Style="{StaticResource ValLabel}"/>
                            </StackPanel>

                        </Canvas>
                    </Grid>
                </Viewbox>
            </TabItem>

