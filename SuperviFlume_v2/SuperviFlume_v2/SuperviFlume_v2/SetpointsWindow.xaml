<Window x:Class="SuperviFlume_v2.SetpointsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SuperviFlume_v2"
        mc:Ignorable="d"
        Title="Setpoints" Height="380" Width="600"
        ResizeMode="NoResize"
        Closing="Window_Closing">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="10"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="10"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="10"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="10"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ── Row 0 : Device + Regulator ──────────────────────────────────── -->
        <StackPanel Grid.Row="0" Orientation="Horizontal">
            <Label Content="Device :" Width="80" VerticalAlignment="Center" FontFamily="Arial"/>
            <ComboBox x:Name="cbDevice" Width="160" FontFamily="Arial"
                      SelectionChanged="cbDevice_SelectionChanged"/>
            <Label Content="Regulator :" Margin="20,0,6,0" VerticalAlignment="Center" FontFamily="Arial"/>
            <RadioButton x:Name="rbTemp" Content="Temperature" FontFamily="Arial"
                         VerticalAlignment="Center" IsChecked="True"
                         Checked="rbRegul_Checked"/>
            <RadioButton x:Name="rbPH" Content="pH" FontFamily="Arial"
                         Margin="12,0,0,0" VerticalAlignment="Center"
                         Checked="rbRegul_Checked"/>
        </StackPanel>

        <!-- ── Row 2 : Ambient value + state ───────────────────────────────── -->
        <StackPanel Grid.Row="2" Orientation="Horizontal">
            <Label x:Name="lblAmbient" Content="Ambient value : ---" FontFamily="Arial"
                   VerticalAlignment="Center" FontStyle="Italic"/>
            <ComboBox x:Name="cbState" Margin="30,0,0,0" VerticalAlignment="Center" Width="110" FontFamily="Arial">
                <ComboBoxItem Content="Disabled"  FontFamily="Arial"/>
                <ComboBoxItem Content="Control"   FontFamily="Arial"/>
                <ComboBoxItem Content="Treatment" FontFamily="Arial"/>
            </ComboBox>
        </StackPanel>

        <!-- ── Row 4 : Offset + Setpoint ────────────────────────────────────── -->
        <Grid Grid.Row="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="110"/>
                <ColumnDefinition Width="110"/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="110"/>
                <ColumnDefinition Width="110"/>
            </Grid.ColumnDefinitions>

            <CheckBox x:Name="chkUseOffset" Content="Use Offset ?" FontFamily="Arial"
                      Grid.Column="0" VerticalAlignment="Center"
                      Checked="chkUseOffset_Changed"
                      Unchecked="chkUseOffset_Changed"/>
            <TextBox x:Name="tbOffset" Grid.Column="1" FontFamily="Arial"
                     Height="24" IsEnabled="False" Padding="4,2"
                     TextChanged="tbOffset_TextChanged"/>
            <Label Content="Setpoint :" Grid.Column="3" FontFamily="Arial"
                   VerticalAlignment="Center"/>
            <TextBox x:Name="tbSetpoint" Grid.Column="4" FontFamily="Arial"
                     Height="24" Padding="4,2"/>
        </Grid>

        <!-- ── Row 6 : PID parameters ───────────────────────────────────────── -->
        <GroupBox Grid.Row="6" Header="PID parameters" FontFamily="Arial">
            <Grid Margin="8,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="30"/>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="30"/>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="30"/>
                    <ColumnDefinition Width="120"/>
                </Grid.ColumnDefinitions>

                <Label Content="Kp :" Grid.Column="0" VerticalAlignment="Center" FontFamily="Arial"/>
                <TextBox x:Name="tbKp" Grid.Column="1" Height="24" Padding="4,2" FontFamily="Arial"/>

                <Label Content="Ki :" Grid.Column="3" VerticalAlignment="Center" FontFamily="Arial"/>
                <TextBox x:Name="tbKi" Grid.Column="4" Height="24" Padding="4,2" FontFamily="Arial"/>

                <Label Content="Kd :" Grid.Column="6" VerticalAlignment="Center" FontFamily="Arial"/>
                <TextBox x:Name="tbKd" Grid.Column="7" Height="24" Padding="4,2" FontFamily="Arial"/>
            </Grid>
        </GroupBox>

        <!-- ── Row 8 : Forcing ──────────────────────────────────────────────── -->
        <StackPanel Grid.Row="8" Orientation="Horizontal">
            <CheckBox x:Name="chkAutorisationForcage" FontFamily="Arial"
                      Content="Forcing authorization"
                      VerticalAlignment="Center"/>
            <Label Content="Forcing setpoint :" FontFamily="Arial"
                   Margin="20,0,6,0" VerticalAlignment="Center"/>
            <TextBox x:Name="tbConsigneForcage" FontFamily="Arial"
                     Width="110" Height="24" Padding="4,2"/>
        </StackPanel>

        <!-- ── Row 10 : Loading label + Submit ──────────────────────────────── -->
        <Grid Grid.Row="10">
            <Label x:Name="lblLoading" Content="Loading..." FontFamily="Arial"
                   HorizontalAlignment="Left" VerticalAlignment="Center"
                   FontStyle="Italic" Foreground="Gray"
                   Visibility="Collapsed"/>
            <Button x:Name="btnSubmit" Content="Submit" FontFamily="Arial"
                    HorizontalAlignment="Right"
                    Width="110" Height="30"
                    Click="btnSubmit_Click"/>
        </Grid>
    </Grid>
</Window>
