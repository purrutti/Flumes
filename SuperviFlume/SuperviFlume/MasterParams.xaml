<Window x:Class="SuperviFlume.MasterParams"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Master Parameters" Height="450" Width="400">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ComboBox Selection -->
        <StackPanel Grid.Row="0" Margin="0,0,0,15">
            <Label Content="Select Condition:" FontWeight="Bold"/>
            <ComboBox x:Name="cbCondition" SelectionChanged="cbCondition_SelectionChanged" Width="200" HorizontalAlignment="Left">
                <ComboBoxItem Content="Hot Water" Tag="1"/>
                <ComboBoxItem Content="Cold Water" Tag="2"/>
                <ComboBoxItem Content="Ambiant Water" Tag="3"/>
            </ComboBox>
        </StackPanel>

        <!-- Temperature Regulation -->
        <GroupBox Grid.Row="1" Header="Temperature Regulation" x:Name="grpTemp" Margin="0,0,0,10">
            <Grid Margin="5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Label Content="Consigne:" Grid.Row="0" Grid.Column="0"/>
                <TextBox x:Name="tbTempCons" Grid.Row="0" Grid.Column="1" Margin="0,2"/>

                <Label Content="Kp:" Grid.Row="1" Grid.Column="0"/>
                <TextBox x:Name="tbTempKp" Grid.Row="1" Grid.Column="1" Margin="0,2"/>

                <Label Content="Ki:" Grid.Row="2" Grid.Column="0"/>
                <TextBox x:Name="tbTempKi" Grid.Row="2" Grid.Column="1" Margin="0,2"/>

                <Label Content="Kd:" Grid.Row="3" Grid.Column="0"/>
                <TextBox x:Name="tbTempKd" Grid.Row="3" Grid.Column="1" Margin="0,2"/>

                <Label Content="Forcage:" Grid.Row="4" Grid.Column="0"/>
                <CheckBox x:Name="chkTempForcage" Grid.Row="4" Grid.Column="1" VerticalAlignment="Center"/>

                <Label Content="Consigne Forcage:" Grid.Row="5" Grid.Column="0"/>
                <TextBox x:Name="tbTempConsForcage" Grid.Row="5" Grid.Column="1" Margin="0,2"/>
            </Grid>
        </GroupBox>

        <!-- Pressure Regulation -->
        <GroupBox Grid.Row="2" Header="Pressure Regulation" x:Name="grpPression" Margin="0,0,0,10">
            <Grid Margin="5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Label Content="Consigne:" Grid.Row="0" Grid.Column="0"/>
                <TextBox x:Name="tbPressionCons" Grid.Row="0" Grid.Column="1" Margin="0,2"/>

                <Label Content="Kp:" Grid.Row="1" Grid.Column="0"/>
                <TextBox x:Name="tbPressionKp" Grid.Row="1" Grid.Column="1" Margin="0,2"/>

                <Label Content="Ki:" Grid.Row="2" Grid.Column="0"/>
                <TextBox x:Name="tbPressionKi" Grid.Row="2" Grid.Column="1" Margin="0,2"/>

                <Label Content="Kd:" Grid.Row="3" Grid.Column="0"/>
                <TextBox x:Name="tbPressionKd" Grid.Row="3" Grid.Column="1" Margin="0,2"/>

                <Label Content="Forcage:" Grid.Row="4" Grid.Column="0"/>
                <CheckBox x:Name="chkPressionForcage" Grid.Row="4" Grid.Column="1" VerticalAlignment="Center"/>

                <Label Content="Consigne Forcage:" Grid.Row="5" Grid.Column="0"/>
                <TextBox x:Name="tbPressionConsForcage" Grid.Row="5" Grid.Column="1" Margin="0,2"/>
            </Grid>
        </GroupBox>

        <!-- Submit Button -->
        <Button Grid.Row="3" x:Name="btnSubmit" Content="Submit" Click="btnSubmit_Click" Width="100" Height="30" HorizontalAlignment="Right"/>
    </Grid>
</Window>
